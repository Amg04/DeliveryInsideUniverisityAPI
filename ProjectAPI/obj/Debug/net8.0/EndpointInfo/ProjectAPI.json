            "type": "integer",
            "format": "int32"
          },
          "newPaymentStatus": {
            "$ref": "#/components/schemas/PaymentStatus"
          }
        },
        "additionalProperties": false
      },
      "RegisterDTO": {
        "required": [
          "address",
          "confirmPassword",
          "email",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string"
          },
          "password": {
            "minLength": 8,
            "type": "string",
            "format": "password"
          },
